# Шаблон для локальной почты. НЕ коммитьте файл с реальными паролями.
#
# Вариант 1 — экспорт в текущей оболочке перед запуском:
#   export SMTP_HOST=smtp.gmail.com
#   export SMTP_PORT=587
#   export SMTP_USERNAME=your@gmail.com
#   export SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
#   ./mvnw spring-boot:run
#
# Вариант 2 — скопируйте этот файл в smtp.env (smtp.env в .gitignore), заполните и:
#   set -a && source smtp.env && set +a && ./mvnw spring-boot:run
#
# IntelliJ / Cursor: Run → Edit Configurations → Environment variables → вставить пары ключ=значение.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
